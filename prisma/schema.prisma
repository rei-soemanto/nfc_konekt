// prisma/schema.prisma

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- ENUMS ---

enum Role {
  USER
  ADMIN
}

enum PlanCategory {
  PERSONAL  
  CORPORATE
}

enum PlanDuration {
  MONTHLY
  SIX_MONTHS
  YEARLY
}

enum UserStatus {
  ACTIVE
  LOCKED
}

enum CardStatus {
  ACTIVE
  INACTIVE
  LOST
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  GRACE_PERIOD
}

enum PlanType {
  PERSONAL
  GROUP
  COMPANY
  LIFETIME
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

enum ShipmentStatus {
  PENDING       // Waiting for payment
  PROCESSING    // Payment received, preparing card
  SHIPPING      // Sent to courier
  ARRIVED       // Delivered
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// --- MODELS ---

model User {
  id             String    @id @default(cuid())
  fullName       String
  email          String    @unique
  phone          String?
  password       String
  companyName    String?
  companyWebsite String?
  avatarUrl      String?   @db.Text
  bio            String?   @db.Text
  
  role           Role        @default(USER)
  accountStatus  UserStatus  @default(ACTIVE)

  address        Address?

  // TEAM / GROUP RELATIONS
  parentId       String?
  parent         User?       @relation("TeamMembers", fields: [parentId], references: [id], onDelete: NoAction)
  members        User[]      @relation("TeamMembers")

  // Relations
  socialLinks    SocialLink[]
  cards          Card[]      @relation("OwnedCards")
  scansMade      Scan[]      @relation("ScansMade")
  subscription   Subscription?

  // NEW: Company / Corporate Profile Fields
  companyScope       String?  // e.g., "Tech", "Logistics"
  companySpeciality  String?  // e.g., "Web Dev", "Supply Chain"
  companyDescription String?  @db.Text
  companyLogoUrl     String?  @db.LongText
  
  // NEW: Employee / Individual Role Fields
  jobTitle           String?  // The "Role on the company"
  isCompanyPublic    Boolean  @default(true) // Admin can toggle this to hide user from public corporate profile

  // Relations
  connections        Connection[] @relation("UserConnections")
  connectedBy        Connection[] @relation("ConnectedBy")

  tempSetupData  String?   @db.Text
  tempDesignData  String?  @db.LongText

  transactions   Transaction[]

  contacts Contact[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Address {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  country     String
  region      String   // State/Province
  city        String
  street      String
  postalCode  String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Connection {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserConnections", fields: [userId], references: [id], onDelete: Cascade)
  
  targetId  String
  target    User     @relation("ConnectedBy", fields: [targetId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([userId, targetId])
  @@index([userId])
}

model Plan {
  id            String        @id @default(cuid())
  category      PlanCategory
  duration      PlanDuration
  price         Int           @default(0)

  name          String        

  expansionPrice Int          @default(0)
  
  subscriptions Subscription[]
  transactions Transaction[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([category, duration])
}

model SocialLink {
  id           String   @id @default(cuid())
  platform     String
  url          String
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Card {
  id             String      @id @default(cuid())
  slug           String      @unique
  hardwareSerial String?     @unique
  
  status         CardStatus  @default(INACTIVE)
  
  userId         String
  user           User        @relation("OwnedCards", fields: [userId], references: [id], onDelete: Cascade)
  
  scansReceived  Scan[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Scan {
  id         String   @id @default(cuid())
  
  scannerId  String
  scanner    User     @relation("ScansMade", fields: [scannerId], references: [id], onDelete: Cascade)
  
  cardId     String
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  
  scannedAt  DateTime @default(now())

  @@index([scannerId])
  @@index([cardId])
}

model Subscription {
  id             String             @id @default(cuid())
  
  userId         String             @unique
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  status         SubscriptionStatus @default(ACTIVE)
  
  planId         String
  plan           Plan               @relation(fields: [planId], references: [id])

  expansionPacks Int                @default(0)

  startDate      DateTime           @default(now())
  endDate        DateTime

  paymentId      String?            @unique
  snapToken      String? 

  shipmentStatus  ShipmentStatus    @default(PENDING)
  shippingAddress String?           @db.Text

  trackingLink    String?
  isNew           Boolean           @default(true)

  pendingTeamData String?           @db.Text
  
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Transaction {
  id              String   @id @default(cuid())
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planId          String?
  plan            Plan?    @relation(fields: [planId], references: [id])
  
  type            String   // 'NEW', 'EXPANSION', 'RENEWAL'
  status          String   // 'PENDING', 'PAID', 'EXPIRED', 'FAILED'
  
  amount          Float
  paymentId       String   @unique // Midtrans Order ID
  snapToken       String?
  
  // Shipment & Fulfillment Data (Snapshot)
  shippingAddress String?  @db.Text
  shipmentStatus  String   @default("PENDING") // 'PENDING' (Unpaid), 'PROCESSING', 'SHIPPING', 'ARRIVED'
  trackingLink    String?
  
  // Content Data
  expansionPacks  Int      @default(0)
  pendingTeamData String?  @db.Text // The list of users to create upon success of THIS specific transaction
  cardDesign      String?  @db.LongText
  
  isNew           Boolean  @default(true) // For Admin Notification

  promoCodeId     String?
  discountApplied Float        @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Contact {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  email       String?
  company     String?
  website     String?
  phone       String?  // Good to have for business cards
  jobTitle    String?  // Good to have
  
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([userId])
}

model PromoCode {
  id              String       @id @default(cuid())
  name            String       // Internal name (e.g., "Summer Sale 2026")
  code            String       @unique // The code user types (e.g., "SUMMER50")
  type            DiscountType
  value           Float        // e.g., 50 (for 50%) or 10000 (for IDR 10k)
  
  // Constraints
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean      @default(true)
  
  // Logic: Array of Plan IDs or Categories this applies to. 
  // Stored as JSON to allow flexibility (e.g., ["PERSONAL", "CORPORATE", "EXPANSION"])
  applicablePlans Json?        

  // Analytics
  usageCount      Int          @default(0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}