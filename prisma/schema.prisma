// prisma/schema.prisma

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- ENUMS ---

enum Role {
  USER
  ADMIN
}

enum CardStatus {
  ACTIVE
  INACTIVE
  LOST
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  GRACE_PERIOD
}

enum PlanType {
  PERSONAL
  GROUP
  COMPANY
  LIFETIME
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

// --- MODELS ---

model User {
  id             String    @id @default(cuid())
  fullName       String
  email          String    @unique
  secondaryEmail String?
  password       String
  companyName    String?
  companyWebsite String?
  avatarUrl      String?   @db.Text
  bio            String?   @db.Text
  
  role           Role      @default(USER)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  socialLinks    SocialLink[]
  cards          Card[]    @relation("OwnedCards")
  
  // Scans I have made (Scanning History)
  scansMade      Scan[]    @relation("ScansMade")
  
  // My active subscription
  subscription   Subscription?

  // Friend Relations
  friendsAsUser   Friend[]  @relation("UserFriends")
  friendsAsFriend Friend[]  @relation("FriendUsers")
}

model Friend {
  id        String       @id @default(cuid())
  
  userId    String
  user      User         @relation("UserFriends", fields: [userId], references: [id])
  
  friendId  String
  friend    User         @relation("FriendUsers", fields: [friendId], references: [id])
  
  status    FriendStatus @default(PENDING)
  
  createdAt DateTime     @default(now())

  @@unique([userId, friendId])
}

model SocialLink {
  id           String   @id @default(cuid())
  platform     String   // e.g., "Whatsapp", "LinkedIn"
  url          String
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Card {
  id             String      @id @default(cuid())
  slug           String      @unique
  hardwareSerial String?     @unique
  
  status         CardStatus  @default(INACTIVE)
  
  userId         String
  user           User        @relation("OwnedCards", fields: [userId], references: [id])
  
  scansReceived  Scan[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Scan {
  id         String   @id @default(cuid())
  
  scannerId  String
  scanner    User     @relation("ScansMade", fields: [scannerId], references: [id])
  
  cardId     String
  card       Card     @relation(fields: [cardId], references: [id])
  
  scannedAt  DateTime @default(now())

  @@index([scannerId])
  @@index([cardId])
}

model Subscription {
  id             String             @id @default(cuid())
  
  userId         String             @unique
  user           User               @relation(fields: [userId], references: [id])
  
  status         SubscriptionStatus @default(ACTIVE)
  planType       PlanType
  
  startDate      DateTime           @default(now())
  endDate        DateTime
  
  paymentRef     String?
  
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}